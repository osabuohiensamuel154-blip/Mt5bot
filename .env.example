# Capital.com API credentials
CAPITAL_API_KEY=your_api_key_here
CAPITAL_EMAIL=your_email_here
CAPITAL_PASSWORD=your_password_here

# 'demo' for paper trading, 'live' for real money
CAPITAL_ENV=demo

# Comma-separated list of pairs to trade simultaneously
# Remove any pair you don't want traded
SYMBOLS=EURUSD,GBPUSD,AUDUSD,NZDUSD,USDCAD,USDCHF,USDJPY,EURJPY,GBPJPY,XAUUSD,US100,US30

# Candle timeframe
TIMEFRAME=HOUR

# Risk settings
RISK_PER_TRADE=0.01        # 1% account risk per trade
DAILY_LOSS_LIMIT=0.03      # halt all trading at 3% drawdown

# 0 = unlimited (high-quality strategy filters are the only gate)
MAX_TRADES_PER_DAY=0

# Telegram notifications (optional — leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
