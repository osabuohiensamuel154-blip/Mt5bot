# Capital.com API credentials
CAPITAL_API_KEY=your_api_key_here
CAPITAL_EMAIL=your_email_here
CAPITAL_PASSWORD=your_password_here

# 'demo' for paper trading, 'live' for real money
CAPITAL_ENV=demo

# Trading parameters
SYMBOL=EURUSD
TIMEFRAME=HOUR
RISK_PER_TRADE=0.01
STOP_LOSS_PIPS=20
TAKE_PROFIT_PIPS=40
# 0 = unlimited (quality filters in strategy.py are the only gate)
MAX_TRADES_PER_DAY=0
DAILY_LOSS_LIMIT=0.03

# Telegram notifications (optional — leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
